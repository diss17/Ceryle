# ──────────────────────────────────────────────
# Ceryle - Variables de Entorno
# Copia este archivo como .env y completa los valores
# ──────────────────────────────────────────────

# --- Inferencia LLM ---
# API Key de Google Gemini (obligatoria si USE_LOCAL_MODEL=false)
GEMINI_API_KEY=tu-api-key-aqui

# Usar modelo local (Ollama) en vez de Gemini remoto
# Valores: true | false
USE_LOCAL_MODEL=false

# Configuración de Ollama (solo si USE_LOCAL_MODEL=true)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Aplicación ---
APP_ENV=development
LOG_LEVEL=info
